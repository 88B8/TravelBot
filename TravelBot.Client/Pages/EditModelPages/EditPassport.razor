@page "/Passport/Edit/{Id:guid}"
@using Blazored.FluentValidation
@using TravelBot.Client.Contracts.Client
@using TravelBot.Client.Validators
@inject ITravelBotApiClient TravelBotApiClient
@inject NavigationManager NavigationManager

<PageTitle>Изменение паспорта</PageTitle>

<h3>Изменение паспорта</h3>

@if (isLoading)
{
    <p>Загрузка...</p>
}
else if (item == null)
{
    <p class="text-danger">Паспорт не найден.</p>
}
else
{
    <EditForm Model="item" OnValidSubmit="HandleSubmit">
        <FluentValidationValidator Validator="validator"></FluentValidationValidator>

        <div class="form-group mb-3">
            <label>Посещённые места:</label>

            @if (item.PlaceIds.Any())
            {
                <ul class="list-group mb-2">
                    @foreach (var placeId in item.PlaceIds)
                    {
                        var place = allPlaces.FirstOrDefault(p => p.Id == placeId);
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            @(place?.Name ?? "Неизвестное место")
                            <button type="button" class="btn btn-sm btn-danger" @onclick="() => RemovePlace(placeId)">Удалить</button>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">Нет добавленных мест</p>
            }

            <div class="input-group">
                <select class="form-select" @bind="selectedPlaceId">
                    <option value="">Выберите место для добавления</option>
                    @foreach (var place in allPlaces)
                    {
                        <option value="@place.Id">@place.Name</option>
                    }
                </select>
                <button type="button" class="btn btn-primary" @onclick="AddPlace">Добавить</button>
            </div>
            <ValidationMessage For="@(() => item.PlaceIds)" />
        </div>

        <div class="d-flex justify-content-end mt-3">
            <button type="submit" class="btn btn-success">Сохранить</button>
            <button type="button" class="btn btn-secondary ms-2" @onclick="Cancel">Отмена</button>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private PassportCreateApiModel? item;
    private PassportCreateApiModelValidator validator = new();
    private List<PlaceApiModel> allPlaces = new();
    private string? selectedPlaceId;
    private bool isLoading = true;
    private CancellationTokenSource cancellationTokenSource = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var passport = await TravelBotApiClient.PassportGETAsync(Id, cancellationTokenSource.Token);

            allPlaces = (await TravelBotApiClient.PlaceAllAsync(cancellationTokenSource.Token))?.ToList() ?? new();

            if (passport != null)
            {
                item = new PassportCreateApiModel
                    {
                        PlaceIds = passport.Places.Select(p => p.Id).ToList()
                    };
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при загрузке паспорта: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AddPlace()
    {
        if (string.IsNullOrEmpty(selectedPlaceId) || item == null)
            return;

        var placeId = Guid.Parse(selectedPlaceId);
        if (!item.PlaceIds.Contains(placeId))
            item.PlaceIds.Add(placeId);

        selectedPlaceId = null;
        StateHasChanged();
    }

    private void RemovePlace(Guid placeId)
    {
        item?.PlaceIds.Remove(placeId);
        StateHasChanged();
    }

    private async Task HandleSubmit()
    {
        if (item == null)
            return;

        var result = await validator.ValidateAsync(item);
        if (!result.IsValid)
            return;

        try
        {
            await TravelBotApiClient.PassportPUTAsync(Id, item, cancellationTokenSource.Token);
            NavigationManager.NavigateTo("/Passport");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при сохранении паспорта: {ex.Message}");
        }
    }

    private void Cancel() => NavigationManager.NavigateTo("/Passport");
}
