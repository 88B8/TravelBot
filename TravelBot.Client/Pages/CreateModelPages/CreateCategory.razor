@page "/Category/Create"
@using Blazored.FluentValidation
@using TravelBot.Client.Contracts.Client
@using TravelBot.Client.Validators
@inject ITravelBotApiClient TravelBotApiClient
@inject NavigationManager NavigationManager

<PageTitle>Создание категории</PageTitle>

<h3>Создание категории</h3>

<EditForm Model="item" OnValidSubmit="HandleSubmit">
	<FluentValidationValidator Validator="validator"></FluentValidationValidator>

	<div class="form-group">
		<label for="Name">Название:</label>
		<InputText id="Name" @bind-Value="item.Name" class="form-control"/>
		<ValidationMessage For="@(() => item.Name)"></ValidationMessage>
	</div>

	<div class="d-flex justify-content-end mt-3">
		<button type="submit" class="btn btn-success">Создать</button>
		<button type="button" class="btn btn-secondary ms-2" @onclick="Cancel">Отмена</button>
	</div>
</EditForm>

@code {
	private readonly CategoryCreateApiModel item = new();
	private readonly CategoryCreateApiModelValidator validator = new();
	private readonly CancellationTokenSource cancellationTokenSource = new();

	private async Task HandleSubmit()
	{
		var result = await validator.ValidateAsync(item, cancellationTokenSource.Token);

		if (result.IsValid)
		{
			await TravelBotApiClient.CategoryPOSTAsync(item, cancellationTokenSource.Token);
			NavigationManager.NavigateTo("Category");
		}
	}

	private void Cancel()
	{
		NavigationManager.NavigateTo("Category");
	}
}