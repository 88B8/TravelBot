@page "/Passport"
@using TravelBot.Api.Client.Client
@inject NavigationManager NavigationManager
@inject ITravelBotApiClient TravelBotClient
@inject IJSRuntime JsRuntime

<PageTitle>Главная. Паспорта</PageTitle>

<div>
	<button class="btn btn-primary" @onclick="AddPassport">
		<i class="fas fa-plus"></i> Добавить паспорт
	</button>
</div>
<hr/>

@if (items.Count == 0)
{
	<p><em>Нет паспортов</em></p>
}
else
{
	<table class="table table-striped">
		<thead>
		<tr>
			<th>Идентификатор</th>
			<th>Посещённые места</th>
			<th>Действия</th>
		</tr>
		</thead>
		<tbody>
		@foreach (var item in items)
		{
			<tr>
				<td>@item.Id</td>
				<td>
					@if (item.Places != null && item.Places.Any())
					{
						<ul class="list-unstyled mb-0">
							@foreach (var place in item.Places)
							{
								<li>
									<i class="bi bi-geo-alt-fill text-primary"></i> @place.Name
								</li>
							}
						</ul>
					}
					else
					{
						<span class="text-muted">Нет мест</span>
					}
				</td>
				<td>
					<select class="form-select" @onchange="@(e => HandleActionSelection(item.Id, e.Value?.ToString()))">
						<option value="">Выберите действие</option>
						<option value="Edit">Изменить</option>
						<option value="Delete">Удалить</option>
					</select>
				</td>
			</tr>
		}
		</tbody>
	</table>
}

@code {
	private readonly CancellationTokenSource cancellationTokenSource = new();
	private ICollection<PassportApiModel> items = new List<PassportApiModel>();

	private void AddPassport()
	{
		NavigationManager.NavigateTo("Passport/Create");
	}

	private async Task HandleActionSelection(Guid id, string? action)
	{
		if (string.IsNullOrEmpty(action))
		{
			return;
		}

		switch (action)
		{
			case "Edit":
				NavigationManager.NavigateTo($"/Passport/Edit/{id}");
				break;

			case "Delete":
				var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", "Вы уверены, что хотите удалить этот паспорт?");
				if (confirmed)
				{
					await TravelBotClient.PassportDeleteAsync(id, cancellationTokenSource.Token);
					var item = items.FirstOrDefault(x => x.Id == id);

					if (item != null)
					{
						items.Remove(item);
						StateHasChanged();
					}
				}

				break;
		}
	}

	protected override async Task OnInitializedAsync()
	{
		try
		{
			items = await TravelBotClient.PassportGetAllAsync(cancellationTokenSource.Token)
			        ?? new List<PassportApiModel>();
		}
		catch (ApiException ex) when (ex.StatusCode == 401)
		{
			NavigationManager.NavigateTo("/login", true);
		}
	}
}