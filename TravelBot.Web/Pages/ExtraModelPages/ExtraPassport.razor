@page "/Passport/{Id:guid}"
@using TravelBot.Api.Client.Client
@inject ITravelBotApiClient TravelBotApiClient

<PageTitle>Паспорт @item?.Id.ToString()</PageTitle>

<h3>Паспорт</h3>
<hr size="3"/>

@if (item == null)
{
	<p class="text-danger">Паспорт не найден.</p>
}
else
{
	<table class="table table-striped">
		<thead>
		<tr>
			<th>Идентификатор</th>
			<th>Посещённые места</th>
		</tr>
		</thead>
		<tbody>
		<tr>
			<td>@item.Id</td>
			<td>
				@if (item.Places != null && item.Places.Any())
				{
					<ul class="list-unstyled mb-0">
						@foreach (var place in item.Places)
						{
							<li>
								<i class="bi bi-geo-alt-fill text-primary"></i> @place.Name
							</li>
						}
					</ul>
				}
				else
				{
					<span class="text-muted">Нет мест</span>
				}
			</td>
		</tr>
		</tbody>
	</table>
}

@code {
	[Parameter] public Guid Id { get; set; }
	private PassportApiModel? item;
	private readonly CancellationTokenSource cancellationTokenSource = new();

	protected override async Task OnInitializedAsync()
	{
		try
		{
			item = await TravelBotApiClient.PassportGetByIdAsync(Id, cancellationTokenSource.Token);
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Ошибка при загрузке паспорта: {ex.Message}");
		}
	}

}
